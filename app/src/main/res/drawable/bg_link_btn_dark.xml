<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <solid android:color="#2E1E6A" />
            <corners android:radius="12dp" />
            <stroke
                android:width="1.5dp"
                android:color="#5B4ACA" />
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="@color/dark_surface_2" />
            <corners android:radius="12dp" />
            <stroke
                android:width="1dp"
                android:color="#3D2E7A" />
        </shape>
    </item>
</selector>
