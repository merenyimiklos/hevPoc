<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.HevPoc" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/red_ambulance</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/red_ambulance</item>
        <item name="colorSecondary">@color/blue_police</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorTertiary">@color/yellow_fire</item>
        <item name="colorOnTertiary">@color/white</item>
        <item name="colorSurface">@color/surface_card</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>
        <item name="colorOutline">@color/border_default</item>
        <item name="android:windowBackground">@color/bg_app</item>
    </style>

    <style name="Theme.HevPoc" parent="Base.Theme.HevPoc" />

    <!-- Reusable text appearance styles -->
    <style name="TextAppearance.HevPoc.ButtonLabel" parent="Widget.Material3.Button">
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>