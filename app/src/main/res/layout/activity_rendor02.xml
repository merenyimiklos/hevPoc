<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rendor02Root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/blue_police">

    <!-- ═══ HEADER ═══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1.8"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/rendor_title"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:textStyle="bold"
            android:letterSpacing="0.1" />

        <ImageView
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_police"
            android:contentDescription="@string/rendor_title" />

    </LinearLayout>

    <!-- ═══ WHITE CARD ═══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="8.2"
        android:orientation="vertical"
        android:background="@drawable/bg_card_top_rounded"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="14dp"
        android:paddingBottom="12dp">

        <!-- Category instruction label -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:text="@string/rendor02_cat_label"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:gravity="center" />

        <!-- Row 1: EMBERRABLÁS | TÁMADÁS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginBottom="5dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCatKidnap"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="5dp"
                android:text="@string/rendor02_cat_kidnap"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:textAllCaps="true"
                app:strokeColor="@color/blue_police"
                app:strokeWidth="2dp"
                app:cornerRadius="14dp"
                app:backgroundTint="@color/white" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCatAttack"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="5dp"
                android:text="@string/rendor02_cat_attack"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:textAllCaps="true"
                app:strokeColor="@color/blue_police"
                app:strokeWidth="2dp"
                app:cornerRadius="14dp"
                app:backgroundTint="@color/white" />

        </LinearLayout>

        <!-- Row 2: RABLÁS | SZEXUÁLIS ZAKLATÁS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginBottom="5dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCatRobbery"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="5dp"
                android:text="@string/rendor02_cat_robbery"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:textAllCaps="true"
                app:strokeColor="@color/blue_police"
                app:strokeWidth="2dp"
                app:cornerRadius="14dp"
                app:backgroundTint="@color/white" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCatHarassment"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="5dp"
                android:text="@string/rendor02_cat_harassment"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:textAllCaps="true"
                app:strokeColor="@color/blue_police"
                app:strokeWidth="2dp"
                app:cornerRadius="14dp"
                app:backgroundTint="@color/white" />

        </LinearLayout>

        <!-- Row 3: BANKRABLÁS | FEGYVERES ELKÖVETŐ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginBottom="5dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCatBankRobbery"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="5dp"
                android:text="@string/rendor02_cat_bank_robbery"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:textAllCaps="true"
                app:strokeColor="@color/blue_police"
                app:strokeWidth="2dp"
                app:cornerRadius="14dp"
                app:backgroundTint="@color/white" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCatArmed"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="5dp"
                android:text="@string/rendor02_cat_armed"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:textAllCaps="true"
                app:strokeColor="@color/blue_police"
                app:strokeWidth="2dp"
                app:cornerRadius="14dp"
                app:backgroundTint="@color/white" />

        </LinearLayout>

        <!-- Row 4: VAGYON ELLENI CSELEKMÉNY (full-width) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCatProperty"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginBottom="5dp"
            android:text="@string/rendor02_cat_property"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:textAllCaps="true"
            app:strokeColor="@color/blue_police"
            app:strokeWidth="2dp"
            app:cornerRadius="14dp"
            app:backgroundTint="@color/white" />

        <!-- Vagyon sub-section (GONE until VAGYON ELLENI selected) -->
        <LinearLayout
            android:id="@+id/vagyonSubSection"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="3"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- Sub-row 1: OKMÁNYOK | BETÖRÉS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginBottom="5dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCatDocs"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="5dp"
                    android:text="@string/rendor02_cat_property_docs"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:textAllCaps="true"
                    app:strokeColor="@color/blue_police"
                    app:strokeWidth="2dp"
                    app:cornerRadius="14dp"
                    app:backgroundTint="@color/white" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCatBurglary"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="5dp"
                    android:text="@string/rendor02_cat_property_burglary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:textAllCaps="true"
                    app:strokeColor="@color/blue_police"
                    app:strokeWidth="2dp"
                    app:cornerRadius="14dp"
                    app:backgroundTint="@color/white" />

            </LinearLayout>

            <!-- Sub-row 2: JÁRMŰ | KÉSZPÉNZ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginBottom="5dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCatVehicle"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="5dp"
                    android:text="@string/rendor02_cat_property_vehicle"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:textAllCaps="true"
                    app:strokeColor="@color/blue_police"
                    app:strokeWidth="2dp"
                    app:cornerRadius="14dp"
                    app:backgroundTint="@color/white" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCatCash"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="5dp"
                    android:text="@string/rendor02_cat_property_cash"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:textAllCaps="true"
                    app:strokeColor="@color/blue_police"
                    app:strokeWidth="2dp"
                    app:cornerRadius="14dp"
                    app:backgroundTint="@color/white" />

            </LinearLayout>

            <!-- Egyéb text field -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:hint="@string/rendor02_cat_other_hint">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etEgyeb"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:inputType="text"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary" />

            </com.google.android.material.textfield.TextInputLayout>

        </LinearLayout>

        <!-- Spacer -->
        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="0.2" />

        <!-- Bottom action row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRendor02Back"
                android:layout_width="72dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="10dp"
                app:icon="@drawable/ic_arrow_back"
                app:iconGravity="textStart"
                app:iconSize="24dp"
                app:iconTint="@color/white"
                app:backgroundTint="@color/gray_back"
                app:cornerRadius="14dp"
                app:elevation="0dp"
                android:contentDescription="@string/btn_back" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRendor02Next"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="@string/rendor02_next"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                app:backgroundTint="@color/gray_back"
                app:cornerRadius="14dp"
                app:elevation="0dp" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
