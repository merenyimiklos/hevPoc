<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/personalDataRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_gradient_dark">

    <!-- ═══ HEADER (~25 % of screen) ═══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2.5"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <ImageView
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:src="@drawable/logo_2022_512"
            android:contentDescription="@string/terms_app_name" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/terms_app_name"
            android:textColor="@color/text_on_dark"
            android:textSize="17sp"
            android:textStyle="bold"
            android:gravity="center" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="@string/terms_powered_by"
            android:textColor="@color/text_on_dark_secondary"
            android:textSize="11sp" />

        <View
            android:layout_width="36dp"
            android:layout_height="1dp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp"
            android:background="#55FFFFFF" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/personal_data_title"
            android:textColor="@color/text_on_dark"
            android:textSize="13sp"
            android:textStyle="bold"
            android:gravity="center"
            android:letterSpacing="0.08" />

    </LinearLayout>

    <!-- ═══ DARK CARD (rounded top corners, fills rest) ═══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="7.5"
        android:orientation="vertical"
        android:background="@drawable/bg_card_dark_rounded"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="20dp">

        <!-- Required label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="@string/personal_data_required"
            android:textColor="@color/text_on_dark"
            android:textSize="14sp"
            android:textStyle="bold" />

        <!-- Name field -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilName"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:hint="@string/personal_data_name"
            app:boxStrokeColor="@color/text_on_dark_secondary"
            app:hintTextColor="@color/text_on_dark_secondary">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etName"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:inputType="textPersonName"
                android:textSize="16sp"
                android:textColor="@color/text_on_dark" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Date of birth field (tappable, opens DatePickerDialog) -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilDob"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:hint="@string/personal_data_dob"
            app:endIconMode="custom"
            app:endIconDrawable="@drawable/ic_calendar"
            app:endIconContentDescription="@string/personal_data_dob"
            app:boxStrokeColor="@color/text_on_dark_secondary"
            app:hintTextColor="@color/text_on_dark_secondary">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etDob"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:focusable="false"
                android:clickable="true"
                android:inputType="none"
                android:textSize="16sp"
                android:textColor="@color/text_on_dark"
                android:cursorVisible="false" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Address field -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilAddress"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:hint="@string/personal_data_address"
            app:boxStrokeColor="@color/text_on_dark_secondary"
            app:hintTextColor="@color/text_on_dark_secondary">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etAddress"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:inputType="textPostalAddress"
                android:textSize="16sp"
                android:textColor="@color/text_on_dark" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Hearing impaired label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="@string/personal_data_hearing"
            android:textColor="@color/text_on_dark"
            android:textSize="14sp"
            android:textStyle="bold" />

        <!-- Hearing impaired toggle buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnHearingYes"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="@string/personal_data_yes"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:textColor="@color/btn_unselected_dark_text"
                app:backgroundTint="@color/btn_unselected_dark"
                app:cornerRadius="14dp"
                app:elevation="0dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnHearingNo"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="@string/personal_data_no"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:textColor="@color/btn_unselected_dark_text"
                app:backgroundTint="@color/btn_unselected_dark"
                app:cornerRadius="14dp"
                app:elevation="0dp" />

        </LinearLayout>

        <!-- Flexible spacer pushes Save button to the bottom -->
        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Save button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="62dp"
            android:text="@string/personal_data_save"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            app:backgroundTint="@color/gray_back"
            app:cornerRadius="14dp"
            app:elevation="0dp" />

    </LinearLayout>

</LinearLayout>
