<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/homeRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/red_ambulance">

    <!-- ═══ HEADER (red, ~22% of screen) ═══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2.2"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="4dp">

        <ImageView
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:src="@drawable/logo_2022_512"
            android:contentDescription="@string/terms_app_name" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/terms_app_name"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="@string/terms_powered_by"
            android:textColor="#CCffffff"
            android:textSize="12sp" />

    </LinearLayout>

    <!-- ═══ SUBTITLE ROW with overflow menu ═══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="4dp"
        android:paddingBottom="10dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/home_subtitle"
            android:textAlignment="center"
            android:textColor="#CCffffff"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.1" />

        <ImageButton
            android:id="@+id/btnMenu"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_more_vert"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/home_menu"
            android:tint="@color/white"
            android:padding="12dp" />

    </LinearLayout>

    <!-- ═══ WHITE CARD (fills the rest, ~78% of screen) ═══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="7.8"
        android:orientation="vertical"
        android:background="@drawable/bg_card_top_rounded"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="16dp">

        <!-- MENTŐ – ambulance / medical -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAmbulance"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginBottom="10dp"
            android:text="@string/home_ambulance"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:textAllCaps="true"
            android:gravity="start|center_vertical"
            android:paddingStart="24dp"
            android:paddingEnd="20dp"
            app:icon="@drawable/ambulance_2022"
            app:iconSize="52dp"
            app:iconGravity="end"
            app:iconTint="@color/white"
            app:iconPadding="0dp"
            app:backgroundTint="@color/red_ambulance"
            app:cornerRadius="@dimen/corner_button"
            app:elevation="4dp" />

        <!-- TŰZOLTÓ – fire department -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnFire"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginBottom="10dp"
            android:text="@string/home_fire"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:textAllCaps="true"
            android:gravity="start|center_vertical"
            android:paddingStart="24dp"
            android:paddingEnd="20dp"
            app:icon="@drawable/fire_2022"
            app:iconSize="52dp"
            app:iconGravity="end"
            app:iconTint="@color/white"
            app:iconPadding="0dp"
            app:backgroundTint="@color/yellow_fire"
            app:cornerRadius="@dimen/corner_button"
            app:elevation="4dp" />

        <!-- RENDŐR – police -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPolice"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginBottom="10dp"
            android:text="@string/home_police"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:textAllCaps="true"
            android:gravity="start|center_vertical"
            android:paddingStart="24dp"
            android:paddingEnd="20dp"
            app:icon="@drawable/police_2022"
            app:iconSize="52dp"
            app:iconGravity="end"
            app:iconTint="@color/white"
            app:iconPadding="0dp"
            app:backgroundTint="@color/blue_police"
            app:cornerRadius="@dimen/corner_button"
            app:elevation="4dp" />

        <!-- SZEMTANÚ – witness toggle card (icon + label + MaterialSwitch) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginBottom="0dp"
            android:background="@drawable/bg_witness_card"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp">

            <ImageView
                android:id="@+id/ivWitnessIcon"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_eye"
                android:contentDescription="@string/home_witness_label"
                app:tint="@color/gray_witness" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/home_witness_label"
                    android:textColor="@color/text_primary"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvWitnessStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/home_witness_on"
                    android:textColor="@color/green_action"
                    android:textSize="14sp" />

            </LinearLayout>

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchWitness"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:contentDescription="@string/home_witness" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
