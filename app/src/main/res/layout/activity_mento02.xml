<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/mento02Root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/red_ambulance">

    <!-- ═══ HEADER ═══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1.8"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/home_ambulance"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:textStyle="bold"
            android:letterSpacing="0.1" />

        <ImageView
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_medical_cross"
            android:contentDescription="@string/home_ambulance" />

    </LinearLayout>

    <!-- ═══ WHITE CARD ═══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="8.2"
        android:orientation="vertical"
        android:background="@drawable/bg_card_top_rounded"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="14dp"
        android:paddingBottom="12dp">

        <!-- Age group label -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:text="@string/mento02_age_label"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:gravity="center" />

        <!-- Age group buttons row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginBottom="8dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAge0"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="5dp"
                android:text="@string/mento02_age_0_1"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:textAllCaps="true"
                app:strokeColor="@color/red_ambulance"
                app:strokeWidth="2dp"
                app:cornerRadius="14dp"
                app:backgroundTint="@color/white" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAge1"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="5dp"
                android:layout_marginEnd="5dp"
                android:text="@string/mento02_age_1_14"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:textAllCaps="true"
                app:strokeColor="@color/red_ambulance"
                app:strokeWidth="2dp"
                app:cornerRadius="14dp"
                app:backgroundTint="@color/white" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAge2"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="5dp"
                android:text="@string/mento02_age_14plus"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:textAllCaps="true"
                app:strokeColor="@color/red_ambulance"
                app:strokeWidth="2dp"
                app:cornerRadius="14dp"
                app:backgroundTint="@color/white" />

        </LinearLayout>

        <!-- Category label -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:text="@string/mento02_cat_label"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:gravity="center" />

        <!-- Category row 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginBottom="5dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCatHome"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="5dp"
                android:text="@string/mento02_cat_home"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:textAllCaps="true"
                app:strokeColor="@color/red_ambulance"
                app:strokeWidth="2dp"
                app:cornerRadius="14dp"
                app:backgroundTint="@color/white" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCatRoad"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="5dp"
                android:text="@string/mento02_cat_road"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:textAllCaps="true"
                app:strokeColor="@color/red_ambulance"
                app:strokeWidth="2dp"
                app:cornerRadius="14dp"
                app:backgroundTint="@color/white" />

        </LinearLayout>

        <!-- Category row 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginBottom="5dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCatInjury"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="5dp"
                android:text="@string/mento02_cat_injury"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:textAllCaps="true"
                app:strokeColor="@color/red_ambulance"
                app:strokeWidth="2dp"
                app:cornerRadius="14dp"
                app:backgroundTint="@color/white" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCatIll"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="5dp"
                android:text="@string/mento02_cat_ill"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:textAllCaps="true"
                app:strokeColor="@color/red_ambulance"
                app:strokeWidth="2dp"
                app:cornerRadius="14dp"
                app:backgroundTint="@color/white" />

        </LinearLayout>

        <!-- Category row 3 – full-width TRAPPED -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCatTrapped"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginBottom="5dp"
            android:text="@string/mento02_cat_trapped"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:textAllCaps="true"
            app:strokeColor="@color/red_ambulance"
            app:strokeWidth="2dp"
            app:cornerRadius="14dp"
            app:backgroundTint="@color/white" />

        <!-- Category row 4 – full-width ALLERGY -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCatAllergy"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginBottom="5dp"
            android:text="@string/mento02_cat_allergy"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:textAllCaps="true"
            app:strokeColor="@color/red_ambulance"
            app:strokeWidth="2dp"
            app:cornerRadius="14dp"
            app:backgroundTint="@color/white" />

        <!-- Category row 5 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCatPoison"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="5dp"
                android:text="@string/mento02_cat_poison"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:textAllCaps="true"
                app:strokeColor="@color/red_ambulance"
                app:strokeWidth="2dp"
                app:cornerRadius="14dp"
                app:backgroundTint="@color/white" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCatChoke"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="5dp"
                android:text="@string/mento02_cat_choke"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:textAllCaps="true"
                app:strokeColor="@color/red_ambulance"
                app:strokeWidth="2dp"
                app:cornerRadius="14dp"
                app:backgroundTint="@color/white" />

        </LinearLayout>

        <!-- Spacer -->
        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="0.3" />

        <!-- Bottom action row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMento02Back"
                android:layout_width="72dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="10dp"
                app:icon="@drawable/ic_arrow_back"
                app:iconGravity="textStart"
                app:iconSize="24dp"
                app:iconTint="@color/white"
                app:backgroundTint="@color/btn_back"
                app:cornerRadius="14dp"
                app:elevation="0dp"
                android:contentDescription="@string/btn_back" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMento02Next"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="@string/mento02_next"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                app:backgroundTint="@color/gray_back"
                app:cornerRadius="14dp"
                app:elevation="0dp" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
