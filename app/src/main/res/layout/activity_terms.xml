<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/termsRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_gradient_dark">

    <!-- ═══ HEADER (~25 % of screen) ═══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2.5"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <ImageView
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:src="@mipmap/ic_launcher"
            android:contentDescription="@string/terms_app_name" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/terms_app_name"
            android:textColor="@color/text_on_dark"
            android:textSize="17sp"
            android:textStyle="bold"
            android:gravity="center" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="@string/terms_powered_by"
            android:textColor="@color/text_on_dark_secondary"
            android:textSize="11sp" />

        <View
            android:layout_width="36dp"
            android:layout_height="1dp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp"
            android:background="#55FFFFFF" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/terms_title"
            android:textColor="@color/text_on_dark"
            android:textSize="13sp"
            android:textStyle="bold"
            android:gravity="center"
            android:letterSpacing="0.08" />

    </LinearLayout>

    <!-- ═══ DARK CARD (rounded top corners, fills rest) ═══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="7.5"
        android:orientation="vertical"
        android:background="@drawable/bg_card_dark_rounded"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="20dp">

        <!-- Intro text -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/terms_intro"
            android:textColor="@color/text_on_dark_secondary"
            android:textSize="14sp"
            android:gravity="center"
            android:lineSpacingMultiplier="1.3" />

        <!-- Link buttons row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="14dp">

            <LinearLayout
                android:id="@+id/btnAuf"
                android:layout_width="0dp"
                android:layout_height="62dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_link_btn_dark"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/terms_auf_short"
                    android:textColor="@color/red_ambulance"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:gravity="center" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/terms_auf_tap"
                    android:textColor="@color/text_on_dark_secondary"
                    android:textSize="10sp"
                    android:gravity="center" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnPrivacy"
                android:layout_width="0dp"
                android:layout_height="62dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_link_btn_dark"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/terms_privacy_short"
                    android:textColor="@color/blue_police"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:gravity="center" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/terms_privacy_tap"
                    android:textColor="@color/text_on_dark_secondary"
                    android:textSize="10sp"
                    android:gravity="center" />

            </LinearLayout>

        </LinearLayout>

        <!-- Flexible spacer fills remaining height between links and checkboxes -->
        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Checkbox row 1: full-width tap target -->
        <LinearLayout
            android:id="@+id/rowCheckAuf"
            android:layout_width="match_parent"
            android:layout_height="68dp"
            android:layout_marginBottom="10dp"
            android:background="@drawable/bg_check_row_dark"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <CheckBox
                android:id="@+id/cbAuf"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clickable="false"
                android:focusable="false"
                android:scaleX="1.3"
                android:scaleY="1.3" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:paddingStart="14dp"
                android:paddingEnd="0dp"
                android:text="@string/terms_accept_auf"
                android:textColor="@color/text_on_dark"
                android:textSize="14sp"
                android:lineSpacingMultiplier="1.2" />

        </LinearLayout>

        <!-- Checkbox row 2: full-width tap target -->
        <LinearLayout
            android:id="@+id/rowCheckPrivacy"
            android:layout_width="match_parent"
            android:layout_height="68dp"
            android:layout_marginBottom="10dp"
            android:background="@drawable/bg_check_row_dark"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <CheckBox
                android:id="@+id/cbPrivacy"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clickable="false"
                android:focusable="false"
                android:scaleX="1.3"
                android:scaleY="1.3" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:paddingStart="14dp"
                android:paddingEnd="0dp"
                android:text="@string/terms_accept_privacy"
                android:textColor="@color/text_on_dark"
                android:textSize="14sp"
                android:lineSpacingMultiplier="1.2" />

        </LinearLayout>

        <!-- Disclaimer note -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="@string/terms_disclaimer"
            android:textColor="@color/text_on_dark_secondary"
            android:textSize="11sp"
            android:gravity="center" />

        <!-- Action buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="62dp"
            android:layout_marginBottom="20dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnExit"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="@string/btn_exit"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                app:backgroundTint="@color/red_ambulance"
                app:cornerRadius="14dp"
                app:elevation="0dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAccept"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="@string/btn_accept"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                app:backgroundTint="@color/gray_back"
                app:cornerRadius="14dp"
                app:elevation="0dp" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
